---
import StandardLayout from '@/layouts/StandardLayout.astro';
import SafeIcon from '@/components/common/SafeIcon';
---

<StandardLayout title="Under Construction" description="This page is currently being built.">
  <div class="min-h-full flex items-center justify-center page-body py-12">
    <div class="max-w-md text-center space-y-6">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 mb-4">
        <SafeIcon name="Code2" className="w-12 h-12 text-primary" client:load />
      </div>
      <h1 class="text-page-title">Under Construction</h1>
      <p class="text-body text-muted-foreground">
        This page is currently being crafted with precision. Check back soon to see the finished work.
      </p>
      <a href="./home.html" class="btn-primary inline-flex">
        Return Home
      </a>
    </div>
  </div>
</StandardLayout>
    