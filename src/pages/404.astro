---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SafeIcon from '@/components/common/SafeIcon'
---

<BaseLayout title="404 | Page Not Found" description="The page you requested could not be found.">
  <div class="min-h-screen flex items-center justify-center page-body">
    <div class="max-w-md text-center space-y-6">
      <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-primary/10 mb-4">
        <SafeIcon name="SearchX" className="w-12 h-12 text-primary" client:load />
      </div>
      <h1 class="text-page-title">Page Not Found</h1>
      <p class="text-body text-muted-foreground">
        The page you are trying to access does not exist or the link is no longer available.
      </p>
      <a href="./home.html" class="btn-primary inline-flex">
        Return Home
      </a>
    </div>
  </div>
</BaseLayout>
